<group name="local,secureshop">

  <rule id="100100" level="12">
    <if_group>syscheck_entry_added</if_group>
    <field name="syscheck.path" type="pcre2">/uploads/</field>
    <description>[CRITICAL] New file added in /uploads/ directory</description>
    <group>secureshop,webshell,attack,t1505.003</group>
  </rule>

  <rule id="100101" level="15">
    <if_sid>100100</if_sid>
    <field name="syscheck.path" type="pcre2">\.php$</field>
    <description>[CRITICAL] PHP WEBSHELL uploaded to /uploads/ — Active Response triggered</description>
    <group>secureshop,webshell,attack,t1505.003</group>
  </rule>

  <rule id="100110" level="10">
    <if_group>syscheck_entry_modified</if_group>
    <field name="syscheck.path" type="pcre2">\.php$</field>
    <description>[HIGH] PHP source file modified — possible code injection</description>
    <group>secureshop,file_integrity,attack,t1565.001</group>
  </rule>

  <rule id="100111" level="12">
    <if_group>syscheck_entry_modified</if_group>
    <field name="syscheck.path" type="pcre2">db\.php|schema\.sql</field>
    <description>[CRITICAL] Database config or schema modified</description>
    <group>secureshop,file_integrity,attack</group>
  </rule>

  <rule id="100112" level="12">
    <if_group>syscheck_entry_added</if_group>
    <field name="syscheck.path" type="pcre2">\.htaccess$</field>
    <description>[CRITICAL] .htaccess file created — possible access control bypass</description>
    <group>secureshop,file_integrity,attack,t1036</group>
  </rule>

  <rule id="100113" level="10">
    <if_group>syscheck_entry_modified</if_group>
    <field name="syscheck.path" type="pcre2">\.htaccess$</field>
    <description>[HIGH] .htaccess file modified — possible access control bypass</description>
    <group>secureshop,file_integrity,attack,t1036</group>
  </rule>

</group>
